model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup auxiliares

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Server","Database","dProdutos","dCategoriaProdutos","dSubCategoriaProdutos","dIconesProdutos","dPromocoes","dLojas","dLocalidades","fVendas","dCalendario","medidas_fVendas","aux_classe_produtos","aux_rfv_recencia","aux_rfv_frequencia","aux_rfv_valor","medidas_rfv","Atualiza BI"]

annotation PBI_ProTooling = ["CalcGroup","DevMode"]

ref table dProdutos
ref table dCategoriaProdutos
ref table dSubCategoriaProdutos
ref table fVendas
ref table dIconesProdutos
ref table dPromocoes
ref table dLojas
ref table dLocalidades
ref table dCalendario
ref table medidas_fVendas
ref table parametro_campos_participacao
ref table grupo_calculo_medidas
ref table aux_classe_produtos
ref table aux_rfv_recencia
ref table aux_rfv_frequencia
ref table aux_rfv_valor
ref table medidas_rfv
ref table dUsuariosRLS
ref table 'Atualiza BI'

ref role Admin
ref role Pais

ref cultureInfo en-US

