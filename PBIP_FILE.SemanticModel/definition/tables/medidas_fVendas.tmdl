	measure 'FC Rotulo Vendas liquidas' = [Vendas liquidas]
		displayFolder: 05. Formatações/Demais
		lineageTag: 919f5371-3d7e-4b66-9af9-1e9a7ff05543

		formatStringDefinition = ```
				var _vendasLiquidas = SELECTEDMEASURE()
				var _formataMedida = 
				    SWITCH(
				        TRUE(),
				        _vendasLiquidas >= 1E6, FORMAT(_vendasLiquidas, "#0,,.0 Mi"),
				        _vendasLiquidas >= 1E3, FORMAT(_vendasLiquidas, "#0,.0 K"),
				        _vendasLiquidas >= 0, FORMAT(_vendasLiquidas, "#0")
				    )
				return
				"""" &_formataMedida&""""
				```

	measure 'Texto selecione uma categoria' =
			
			SWITCH(
			    TRUE(),
			    NOT ISFILTERED(dIconesProdutos[Categoria]),"Selecione uma categoria",
			    HASONEFILTER(dIconesProdutos[Categoria]),"Detalhar categoria " & SELECTEDVALUE(dIconesProdutos[Categoria]),
			    "Selecione apenas 1 categoria"
			)
		displayFolder: 05. Formatações/Demais
		lineageTag: 0e800ded-5304-46c1-9838-c975cb11d2d8

	measure 'Pareto Vendas liquidas Marca' = ```
			
			VAR _accVendasLiquidas =
			CALCULATE(
			    [Vendas liquidas],
			    WINDOW(
			        0,ABS,
			        0, REL,
			        ALLSELECTED(dProdutos[Marca]),
			        ORDERBY([Vendas liquidas], DESC)
			    )
			)
			var _vendasLiquidasTotal = 
			CALCULATE(
			    [Vendas liquidas],
			    ALLSELECTED(dProdutos[Marca])
			)
			RETURN
			IF([Vendas liquidas] > 0 ,DIVIDE(_accVendasLiquidas,_vendasLiquidasTotal))
			```
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: 04. Pareto
		lineageTag: 40d185b3-76aa-45f1-8442-d44b69edf1d0

