table medidas_fVendas
	lineageTag: db63eb87-ee5a-4169-8f0e-b6f46434570f

	measure 'Qtd vendida' = SUM(fVendas[Quantidade])
		formatString: #,0
		displayFolder: 01. Básicas
		lineageTag: 0cf110be-ad20-4a2f-90ff-c67ed3d94166

	measure 'Custo total' =
			
			SUMX(
			    fVendas,
			    fVendas[CustoUnitario] * fVendas[Quantidade]
			)
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		displayFolder: 01. Básicas
		lineageTag: b4be72c4-046b-49e3-8709-7f6fa8ac95a7

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Vendas brutas' =
			
			SUMX(
			    fVendas,
			    fVendas[PrecoUnitario] * fVendas[Quantidade]
			)
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		displayFolder: 01. Básicas
		lineageTag: bf00a560-658b-4e49-84b7-ca37e66b6c0b

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Vendas liquidas' =
			
			SUMX(
			    fVendas,
			    (fVendas[PrecoUnitario] * fVendas[Quantidade]) *(1 - RELATED(dPromocoes[PercentualDesconto]))
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		displayFolder: 01. Básicas
		lineageTag: 389d7593-0ac7-4e22-a7dc-2af99335b561

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Desconto = [Vendas brutas] - [Vendas liquidas]
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		displayFolder: 01. Básicas
		lineageTag: 0b156f58-a42c-4a31-b846-4c55a34a7041

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure '% Desconto' = DIVIDE([Vendas brutas] - [Vendas liquidas],[Vendas brutas], 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02. Percentuais
		lineageTag: 29536b64-8326-4360-accf-afe41f24fc3d

