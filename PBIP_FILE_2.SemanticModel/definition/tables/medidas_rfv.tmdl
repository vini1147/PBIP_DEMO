table medidas_rfv
	lineageTag: 4e5b500d-c217-4dc1-800b-05e36fc86a8a

	measure 'V produtos nota' =
			
			VAR _result =
			CALCULATE(
			    SELECTEDVALUE(aux_rfv_valor[ID]),
			    FILTER(
			        aux_rfv_valor,
			        [(V) Vendas liquidas 12M] >= aux_rfv_valor[MIN] &&
			        [(V) Vendas liquidas 12M] <= aux_rfv_valor[MAX] &&
			        [(V) Vendas liquidas 12M]
			    )
			)
			RETURN
			_result
		formatString: 0
		displayFolder: 03. Valor
		lineageTag: ac4c907c-97a0-44bb-8e86-2c74b95287f2

	measure 'R produtos' = ```
			
			var _result =
			    CALCULATE(
			        SELECTEDVALUE(aux_rfv_recencia[ID]),
			        FILTER(
			            aux_rfv_recencia,
			            DATEDIFF( [(R) Ultima compra], MAX( dCalendario[Data] ), DAY ) + 0  >= aux_rfv_recencia[MIN] &&
			            DATEDIFF( [(R) Ultima compra], MAX( dCalendario[Data] ), DAY ) + 0 <= aux_rfv_recencia[MAX] 
			            && [(R) Ultima compra]
			        )
			    )
			RETURN
			_result
			```
		formatString: 0
		displayFolder: 01. Recencia
		lineageTag: 6b2a4ea8-8ac9-41b3-8544-b7b760745f2c

	measure 'Qtd produtos 12M' =
			
			CALCULATE(
			    COUNTROWS(VALUES(fVendas[IdProduto])),
			    DATESINPERIOD(
			        dCalendario[Data],
			        MAX(dCalendario[Data]),
			        -12,
			        MONTH
			    )
			)
		formatString: 0
		displayFolder: 01. Recencia
		lineageTag: 9bd208d6-ee86-4ba2-b0da-01fdd8f69fd0

	measure 'F produtos' =
			
			var _result =
			CALCULATE(
			    SELECTEDVALUE(aux_rfv_frequencia[ID]),
			    FILTER(
			        aux_rfv_frequencia,
			        [(F) Qtd vendas 12M] >= aux_rfv_frequencia[MIN] &&
			        [(F) Qtd vendas 12M] <= aux_rfv_frequencia[MAX] &&
			        [(F) Qtd vendas 12M]
			    )
			)
			RETURN
			_result
		formatString: 0
		displayFolder: 02. Frequencia
		lineageTag: 9eff7634-eab8-4aa9-a365-7ee711e7eca9

	measure '(V) Vendas liquidas 12M' =
			
			CALCULATE(
			    [Vendas liquidas],
			    DATESINPERIOD(
			        dCalendario[Data],
			        MAX(dCalendario[Data]),
			        -12,
			        MONTH
			    )
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		displayFolder: 03. Valor
		lineageTag: 505a2199-9610-41f1-8b33-c402701625dc

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure '(R) Ultima compra' =
			
			CALCULATE(
			    MAX(fVendas[Data]),
			    ALL(dCalendario),
			    dCalendario[Data] <= MAX(dCalendario[Data])
			)
		formatString: Short Date
		displayFolder: 01. Recencia
		lineageTag: 746a70e3-f487-4d2c-bad5-471285dc08e0

	measure '(F) Qtd vendas 12M' =
			
			CALCULATE(
			    [Qtd vendas],
			    DATESINPERIOD(
			        dCalendario[Data],
			        MAX(dCalendario[Data]),
			        -12,
			        MONTH
			    )
			)
		formatString: 0
		displayFolder: 02. Frequencia
		lineageTag: 8bd3bcbf-442b-4961-b37f-01463a044ae5

	measure 'Qtd Produtos RFV' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        --Calcula o (R) da recência
			        DATEDIFF([(R) Ultima compra],MAX(dCalendario[Data]),DAY) >= MIN(aux_rfv_recencia[MIN])
			        && DATEDIFF([(R) Ultima compra],MAX(dCalendario[Data]),DAY) <= MAX(aux_rfv_recencia[MAX])
			        &&
			        --Calcula o (F) de frequencia
			        [(F) Qtd vendas 12M] >= MIN(aux_rfv_frequencia[MIN])
			        && [(F) Qtd vendas 12M] <= MAX(aux_rfv_frequencia[MAX])
			        &&
			        --Calcula o (V) de valor
			        [(V) Vendas liquidas 12M] >= MIN(aux_rfv_valor[MIN])
			        && [(V) Vendas liquidas 12M] <= MAX(aux_rfv_valor[MAX])
			    )
			)
		formatString: 0
		lineageTag: 3c275979-b936-476d-b948-eb42d6401af4

	measure 'F+V produtos' = ([F produtos] + [V produtos nota]) / 2
		lineageTag: b50862b1-7631-421f-9188-5ab9647a1520

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '# Campeoes' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] = 5 &&
			        // [F] = 5 &&
			        // [V] = 5
			        [F+V produtos] = 5
			    )
			)
		displayFolder: 04. Qtd por segemento
		lineageTag: 08c8afde-4832-4edd-afab-1bc3a6b1f894

	measure '# Precisam de atencao' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] = 3 &&
			        [F+V produtos] = 3
			        // [F produtos] = 3 &&
			        // [V produtos] = 3
			    )
			)
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: dffa9af5-e142-4fe6-9e72-8d063c8067d1

	measure '# Produtos fieis' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] >= 3 &&
			        // or( [F] = 4, [F] = 5 ) &&
			        // or( [V] = 4, [V] = 5 )
			        [F+V produtos] >= 4
			    )
			) - [# Campeoes]
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: a4692d5c-4383-4d43-bc59-2846e924a52f

	measure '# Produtos recentes' = ```
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] = 5 &&
			        [F+V produtos] < 2 
			        --&& [F+V produtos] >= 1
			    )
			)
			```
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 2fc373ff-226b-4088-9e9b-98ec32326e5c

	measure '# Em risco' = ```
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        OR( [R produtos] = 1,[R produtos] = 2 ) &&
			        // or( [F] = 4, [F] = 5 ) &&
			        // or( [V] = 4, [V] = 5 )
			        [F+V produtos] >= 3 
			        --&& [F+V produtos] < 5
			    )
			) - [# Nao posso perder-los]
			```
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: a796a038-b3c3-4b35-b863-4ede71f0d0a3

	measure '# Hibernando' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] = 2 &&
			        // [F] = 2 &&
			        // [V] = 2
			        [F+V produtos] < 3 && [F+V produtos] >= 2
			    )
			)
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 46fac077-07be-49bb-a34d-8d9464342909

	measure '# Nao posso perder-los' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] = 1 &&
			        // [F] = 5 &&
			        // [V] = 5
			        [F+V produtos] >= 5
			    )
			)
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: d6b64e6b-7c5a-44a0-b130-3a8713020970

	measure '# Perdidos' = ```
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        OR( [R produtos] = 1, [R produtos] = 2 ) &&
			        // or( [F] = 1, [F] = 2 ) &&
			        // or( [V] = 1, [V] = 2 )
			        [F+V produtos] < 3 
			        --&& [F+V produtos] >= 1
			    )
			) - [# Hibernando]
			```
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 18b57db0-8195-4be9-a949-d779c780089f

	measure '# Potenciais fieis' =
			
			CALCULATE(
			    [Qtd produtos 12M],
			    FILTER(
			        dProdutos,
			        [R produtos] >= 4 &&
			        [F+V produtos] >= 2 && [F+V produtos] < 4
			        // or( [F] = 2, [F] = 3 ) &&
			        // or( [V] = 2, [V] = 3 )
			    )
			)
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 110b1269-a5cf-4f2c-92e1-6fa9822a6008

	measure '# Prestes a hibernar' = ```
			
			CALCULATE(
			    [Qtd produtos],
			    FILTER(
			        dProdutos,
			        [R produtos] = 3 &&
			        // OR( [F] = 2, [F] = 1 ) &&
			        // OR( [V] = 2, [V] = 1 )
			        [F+V produtos] < 3 
			        --&& [F+V produtos] >= 1
			    )
			)
			```
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 9f4d1949-a451-4fbf-91bd-9a87d6e5ecdd

	measure '# Promissores' = ```
			
			CALCULATE(
			    [Qtd produtos],
			    FILTER(
			        dProdutos,
			        [R produtos] = 4 &&
			        // [F] = 1 &&
			        // [V] = 1
			        [F+V produtos] < 2 
			        --&& [F+V produtos] >= 1
			    )
			)
			```
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 9282f325-613f-4e3e-9d36-2b784458e02e

	measure '# Conteudos por segmentacao' =
			
			VAR varClasseRFV = SELECTEDVALUE ( aux_classe_produtos[Segmentação] )
			RETURN
			    SWITCH(
			        TRUE(),
			        varClasseRFV  = "Campeões", [# Campeoes],
			        varClasseRFV  = "Produtos fiéis", [# Produtos fieis],
			        varClasseRFV  = "Potenciais fiéis", [# Potenciais fieis],
			        varClasseRFV  = "Produtos recentes", [# Produtos recentes],
			        varClasseRFV  = "Hibernando", [# Hibernando],
			        varClasseRFV  = "Promissores", [# Promissores],
			        varClasseRFV  = "Precisam de atenção", [# Precisam de atencao],
			        varClasseRFV  = "Prestes a hibernar", [# Prestes a hibernar],
			        varClasseRFV  = "Não posso perder-los", [# Nao posso perder-los],
			        varClasseRFV  = "Em risco", [# Em risco],
			        varClasseRFV  = "Perdidos", [# Perdidos],
			        BLANK()
			    ) + 0
		formatString: 0
		displayFolder: 04. Qtd por segemento
		lineageTag: 6246b339-c721-4efa-a241-6a6b904cd518

