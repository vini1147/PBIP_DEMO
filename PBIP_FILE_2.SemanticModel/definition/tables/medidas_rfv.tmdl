	measure '$ Vendas liquidas por segmentacao' = ```
			
			VAR varClasseRFV = SELECTEDVALUE ( aux_classe_produtos[Segmentação] )
			RETURN
			    SWITCH(
			        TRUE(),
			        varClasseRFV  = "Campeões", [$ Vendas liquidas Campeoes],
			        varClasseRFV  = "Produtos fiéis", [$ Vendas liquidas Produtos fieis],
			        varClasseRFV  = "Potenciais fiéis", [$ Vendas liquidas Potenciais fieis],
			        varClasseRFV  = "Produtos recentes", [$ Vendas liquidas Produtos recentes],
			        varClasseRFV  = "Hibernando", [$ Vendas liquidas Hibernando],
			        varClasseRFV  = "Promissores", [$ Vendas liquidas Promissores],
			        varClasseRFV  = "Precisam de atenção", [$ Vendas liquidas Precisam de atencao],
			        varClasseRFV  = "Prestes a hibernar", [$ Vendas liquidas Prestes a hibernar],
			        varClasseRFV  = "Não posso perder-los", [$ Vendas liquidas Nao posso perde-los],
			        varClasseRFV  = "Em risco", [$ Vendas liquidas Em risco],
			        varClasseRFV  = "Perdidos", [$ Vendas liquidas Perdidos],
			        BLANK()
			    )
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 50c57556-34db-4420-b540-9469342c41c1

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Texto selecione uma Segmentação' =
			
			SWITCH(
			    TRUE(),
			    NOT ISFILTERED(aux_classe_produtos[Segmentação]),"Selecione uma Segmentação",
			    HASONEFILTER(aux_classe_produtos[Segmentação]),"Detalhar Segmentação " & SELECTEDVALUE(aux_classe_produtos[Segmentação]),
			    "Selecione apenas 1 Segmentação"
			)
		lineageTag: 4d3c4d61-a07d-4f31-840e-831780378998

	column 'Coluna 1'
		dataType: string
		isHidden
		lineageTag: d644a788-4edb-4d3b-a031-1beeb715c89e
		summarizeBy: none
		sourceColumn: Coluna 1

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	partition medidas_rfv = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Coluna 1" = _t])
				in
				    Fonte

	annotation PBI_ResultType = Table

