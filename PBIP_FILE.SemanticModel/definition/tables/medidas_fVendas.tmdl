	measure '% Participacao vendas liquidas (categoria-marca-produto)' = ```
			
			var _vendasLiquidas = [Vendas liquidas]
			var _scopoProduto = 
			CALCULATE(
			    [Vendas liquidas],
			    ALLSELECTED(dProdutos[Produto])
			)
			var _scopoMarca = 
			CALCULATE(
			    [Vendas liquidas],
			    ALLSELECTED(dProdutos[Marca])
			)
			var _scopoCategoria = 
			CALCULATE(
			    [Vendas liquidas],
			    ALLSELECTED(dCategoriaProdutos[Categoria])
			)
			var _resultProduto = DIVIDE(_vendasLiquidas,_scopoProduto)
			var _resultMarca = DIVIDE(_vendasLiquidas,_scopoMarca)
			var _resultCategoria = DIVIDE(_vendasLiquidas,_scopoCategoria)
			RETURN
			SWITCH(
			    TRUE(),
			    ISINSCOPE(dProdutos[Produto]),_resultProduto,
			    ISINSCOPE(dProdutos[Marca]),_resultMarca,
			    _resultCategoria
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02. Percentuais
		lineageTag: d01b3daa-c3ff-4edb-86a0-c1ee5d534021

	measure '% Participacao vendas liquidas ignorando filtros (categoria-marca-produto)' = ```
			
			var _vendasLiquidas = [Vendas liquidas]
			var _scopoProduto = 
			CALCULATE(
			    [Vendas liquidas],
			    ALL(dProdutos[Produto]),
			    ALL()
			)
			var _scopoMarca = 
			CALCULATE(
			    [Vendas liquidas],
			    ALL(dProdutos[Marca]),
			    ALL()
			)
			var _scopoCategoria = 
			CALCULATE(
			    [Vendas liquidas],
			    ALL(dCategoriaProdutos[Categoria]),
			    ALL()
			)
			var _resultProduto = DIVIDE(_vendasLiquidas,_scopoProduto)
			var _resultMarca = DIVIDE(_vendasLiquidas,_scopoMarca)
			var _resultCategoria = DIVIDE(_vendasLiquidas,_scopoCategoria)
			RETURN
			SWITCH(
			    TRUE(),
			    ISINSCOPE(dProdutos[Produto]),_resultProduto,
			    ISINSCOPE(dProdutos[Marca]),_resultMarca,
			    _resultCategoria
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 02. Percentuais
		lineageTag: 3ff7216b-f0d9-4e78-9e9e-7a9dbc0633d9

