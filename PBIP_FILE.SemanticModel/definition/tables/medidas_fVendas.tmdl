	measure 'Texto range data RFV' =
			
			var _rangeData =
			CALCULATE(
			    FORMAT(MINX(dCalendario,MIN(dCalendario[Data])),"DD/MM/YYYY") & "-" & FORMAT(MAXX(dCalendario,MAX(dCalendario[Data])),"DD/MM/YYYY"),
			    DATESINPERIOD(
			        dCalendario[Data],
			        MAX(dCalendario[Data]),
			        -12,
			        MONTH
			    )
			)
			RETURN
			"Analisando range de datas -> "& _rangeData
		displayFolder: 05. Formatações/Demais
		lineageTag: 4d6d94f7-2279-4dd7-a838-27fcb915c68a

